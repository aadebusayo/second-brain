# secondbrain environment configuration
# Copy to .env and fill in your keys

# Embedding provider: sentence-transformers | local | openai | anthropic
EMBEDDING_PROVIDER=sentence-transformers

# LLM for entity extraction & consolidation: deepseek | openai | anthropic
SECOND_BRAIN_LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-key-here

# Algorithmic tuning
SECOND_BRAIN_GAMMA=0.6
SECOND_BRAIN_ETA=0.1
SECOND_BRAIN_DECAY_RATE=0.01
SECOND_BRAIN_HOPS=3
SECOND_BRAIN_WIRE_THRESHOLD=0.4

# Consolidation: trigger after N new nodes
SECOND_BRAIN_CONSOLIDATE_EVERY_N=100

# Storage
SECOND_BRAIN_DB_PATH=secondbrain.sqlite
SECOND_BRAIN_LOG_LEVEL=INFO
